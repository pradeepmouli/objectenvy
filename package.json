{
  "name": "objectenvy-workspace",
  "version": "1.0.0",
  "description": "ObjectEnvy monorepo - strongly-typed environment configuration for TypeScript projects",
  "keywords": [
    "config",
    "configuration",
    "env",
    "environment",
    "typescript",
    "type-safe",
    "zod",
    "nested",
    "camelcase",
    "dotenv"
  ],
  "private": true,
  "license": "MIT",
  "homepage": "https://pradeepmouli.github.io/objectenvy/",
  "bugs": {
    "url": "https://github.com/pradeepmouli/objectenvy/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean && rm -rf dist coverage",
    "docs:dev": "pnpm --filter @objectenvy/docs dev",
    "docs:build": "pnpm --filter @objectenvy/docs build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && pnpm -r --filter=objectenvy --filter=objectenvy-cli publish",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@to-skills/cli": "^0.2.1",
    "@to-skills/vitepress": "^0.2.17",
    "@typescript/native-preview": "7.0.0-dev.20260219.1",
    "@vitest/coverage-v8": "^4.1.4",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.61.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "type-fest": "^5.6.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-plugin-to-skills": "^0.6.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.32.0"
  },
  "packageManager": "pnpm@10.32.0",
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)"
}
